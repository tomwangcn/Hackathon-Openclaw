PORT=3001
DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-in-production"
UPLOAD_DIR="../uploads"

# S3-compatible storage (optional, falls back to local)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Jira OAuth (optional)
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# WhatsApp (optional)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=

# Redis (optional, for BullMQ)
REDIS_URL=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# === OpenClaw Gateway (Hackathon - Priority 1) ===
OPENCLAW_GATEWAY_URL=          # ngrok URL to OpenClaw gateway
OPENCLAW_HOOKS_TOKEN=          # Auth token for gateway
OPENCLAW_MODEL=                # Optional: agent name override

# === FLock API (Fallback) ===
FLOCK_API_KEY=                 # FLock API key from flock.io
FLOCK_API_URL=https://api.flock.io

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=            # From @BotFather
TELEGRAM_WEBHOOK_URL=          # Your server URL + /api/telegram/webhook
TELEGRAM_BOT_USERNAME=         # Bot username (without @)

# === App URL ===
APP_URL=http://localhost:5173  # Frontend URL for session links
